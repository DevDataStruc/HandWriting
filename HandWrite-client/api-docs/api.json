  "components": {
    "schemas": {
      "UserProfileDTO": {
        "type": "object",
        "properties": {
          "nickname": {
            "maxLength": 64,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "maxLength": 128,
            "minLength": 0,
            "type": "string"
          },
          "phone": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "avatar": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "RUserVO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，0 表示成功",
            "format": "int32"
          },
          "msg": {
            "type": "string",
            "description": "提示信息"
          },
          "data": {
            "$ref": "#/components/schemas/UserVO"
          },
          "ts": {
            "type": "integer",
            "description": "服务器时间戳（毫秒）",
            "format": "int64"
          },
          "success": {
            "type": "boolean"
          }
        },
        "description": "统一 API 响应"
      },
      "UserVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "username": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          },
          "lastLoginTime": {
            "type": "string",
            "format": "date-time"
          },
          "createTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "description": "用户信息"
      },
      "SampleUploadDTO": {
        "required": [
          "charId",
          "fileKey",
          "fileSize"
        ],
        "type": "object",
        "properties": {
          "charId": {
            "type": "integer",
            "format": "int64"
          },
          "fileKey": {
            "type": "string"
          },
          "fileUrl": {
            "type": "string"
          },
          "fileSize": {
            "type": "integer",
            "format": "int32"
          },
          "sha256": {
            "type": "string"
          },
          "device": {
            "type": "string"
          }
        }
      },
      "RSampleVO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，0 表示成功",
            "format": "int32"
          },
          "msg": {
            "type": "string",
            "description": "提示信息"
          },
          "data": {
            "$ref": "#/components/schemas/SampleVO"
          },
          "ts": {
            "type": "integer",
            "description": "服务器时间戳（毫秒）",
            "format": "int64"
          },
          "success": {
            "type": "boolean"
          }
        },
        "description": "统一 API 响应"
      },
      "SampleVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "charId": {
            "type": "integer",
            "format": "int64"
          },
          "fileKey": {
            "type": "string"
          },
          "fileUrl": {
            "type": "string"
          },
          "fileSize": {
            "type": "integer",
            "format": "int32"
          },
          "device": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          },
          "rejectReason": {
            "type": "string"
          },
          "auditedBy": {
            "type": "integer",
            "format": "int64"
          },
          "auditedTime": {
            "type": "string",
            "format": "date-time"
          },
          "createTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "description": "样本视图"
      },
      "FileSignDTO": {
        "required": [
          "ext",
          "purpose"
        ],
        "type": "object",
        "properties": {
          "purpose": {
            "type": "string"
          },
          "ext": {
            "type": "string"
          },
          "bizId": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "FileSignVO": {
        "type": "object",
        "properties": {
          "bucket": {
            "type": "string",
            "description": "对象存储 Bucket"
          },
          "objectKey": {
            "type": "string",
            "description": "对象 Key（最终路径）"
          },
          "uploadUrl": {
            "type": "string",
            "description": "PUT 方式的上传 URL，前端可直接 PUT 文件"
          },
          "method": {
            "type": "string",
            "description": "上传方式：PUT"
          },
          "expireSeconds": {
            "type": "integer",
            "description": "签名过期时间（秒）",
            "format": "int64"
          },
          "requiredHeader": {
            "type": "string",
            "description": "请求头限制（如不需要可为空）"
          }
        },
        "description": "对象存储直传签名"
      },
      "RFileSignVO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，0 表示成功",
            "format": "int32"
          },
          "msg": {
            "type": "string",
            "description": "提示信息"
          },
          "data": {
            "$ref": "#/components/schemas/FileSignVO"
          },
          "ts": {
            "type": "integer",
            "description": "服务器时间戳（毫秒）",
            "format": "int64"
          },
          "success": {
            "type": "boolean"
          }
        },
        "description": "统一 API 响应"
      },
      "RegisterDTO": {
        "required": [
          "password",
          "username"
        ],
        "type": "object",
        "properties": {
          "username": {
            "maxLength": 64,
            "minLength": 3,
            "pattern": "^[A-Za-z0-9_.-]+$",
            "type": "string"
          },
          "password": {
            "maxLength": 64,
            "minLength": 6,
            "type": "string"
          },
          "nickname": {
            "maxLength": 64,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "maxLength": 128,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "LoginVO": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Access Token"
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh Token"
          },
          "tokenType": {
            "type": "string",
            "description": "Token 类型"
          },
          "expiresIn": {
            "type": "integer",
            "description": "Access Token 过期秒数",
            "format": "int64"
          },
          "user": {
            "$ref": "#/components/schemas/UserInfo"
          }
        },
        "description": "登录成功响应"
      },
      "RLoginVO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，0 表示成功",
            "format": "int32"
          },
          "msg": {
            "type": "string",
            "description": "提示信息"
          },
          "data": {
            "$ref": "#/components/schemas/LoginVO"
          },
          "ts": {
            "type": "integer",
            "description": "服务器时间戳（毫秒）",
            "format": "int64"
          },
          "success": {
            "type": "boolean"
          }
        },
        "description": "统一 API 响应"
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "username": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "description": "用户信息"
      },
      "RefreshTokenDTO": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "RVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，0 表示成功",
            "format": "int32"
          },
