# =============================================================
#  HandWrite-client 环境变量配置
#  此文件由 set-env.* 脚本读取，请勿改 key 名（须与 application.yml 保持一致）
#  复制本文件为 .env 后填入实际值：
#      cp .env.example .env
# =============================================================

# ---- Server ----
SERVER_PORT=8080
SERVER_TOMCAT_MAX_THREADS=200
SPRING_PROFILES_ACTIVE=dev
APP_TIMEZONE=Asia/Shanghai

# ---- MySQL (必填) ----
DB_HOST=databaseforjava.mysql.database.azure.com
DB_PORT=3306
DB_NAME=handwriting
DB_USERNAME=azuredatabase
DB_PASSWORD=Zhaozekun2005
DB_USE_SSL=false
DB_TIMEZONE=Asia/Shanghai
DB_POOL_MAX=20
DB_POOL_MIN=5

# ---- JPA / Flyway ----
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true

# ---- Redis ----
REDIS_HOST=20.255.155.28
REDIS_PORT=6379
REDIS_PASSWORD=redis-zhaozekun2005
REDIS_DATABASE=0
REDIS_POOL_MAX_ACTIVE=16

# ---- Mail (SMTP) ----
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SSL_TRUST=smtp.example.com

# ---- Upload ----
UPLOAD_MAX_FILE_SIZE=10MB
UPLOAD_MAX_REQUEST_SIZE=20MB

# ---- Logging ----
LOG_LEVEL_APP=DEBUG
LOG_FILE_PATH=logs/handwriting-client.log

# ---- JWT (⚠️ 生产环境必须修改 JWT_SECRET!) ----
# 重新生成：openssl rand -base64 32
JWT_SECRET=YymVKMo6W1Gt5wcRve4EbX1swoFtqa+qrrKIlYiE9E0=
JWT_ISSUER=handwriting-client
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_HEADER=Authorization
JWT_PREFIX=Bearer

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Object Storage (MinIO / S3) ----
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio123
STORAGE_REGION=us-east-1
STORAGE_BUCKET_COLLECT=handwriting-collect
STORAGE_BUCKET_AUDIT=handwriting-audit
STORAGE_BUCKET_BACKUP=handwriting-backup
STORAGE_PRESIGN_EXPIRE=600
STORAGE_PUBLIC_BASE_URL=

# ---- Rate Limit ----
RATELIMIT_AUTH_PER_MIN=20
RATELIMIT_UPLOAD_PER_MIN=60
