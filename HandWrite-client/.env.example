# =============================================================
#  HandWrite-client 环境变量配置
#  此文件由 set-env.* 脚本读取，请勿改 key 名（须与 application.yml 保持一致）
#  复制本文件为 .env 后填入实际值：
#      cp .env.example .env
#
#  ⚠️ 所有变量均带 HANDWRITE_ 前缀，避免与其他项目冲突
# =============================================================

# ---- Server ----
HANDWRITE_SERVER_PORT=8080
HANDWRITE_SERVER_TOMCAT_MAX_THREADS=200
HANDWRITE_SPRING_PROFILES_ACTIVE=dev
HANDWRITE_APP_TIMEZONE=Asia/Shanghai

# ---- MySQL (必填) ----
HANDWRITE_DB_HOST=127.0.0.1
HANDWRITE_DB_PORT=3306
HANDWRITE_DB_NAME=handwriting
HANDWRITE_DB_USERNAME=handwriting
HANDWRITE_DB_PASSWORD=HandWrite@2026
HANDWRITE_DB_USE_SSL=false
HANDWRITE_DB_TIMEZONE=Asia/Shanghai
HANDWRITE_DB_POOL_MAX=20
HANDWRITE_DB_POOL_MIN=5

# ---- JPA / Flyway ----
HANDWRITE_JPA_DDL_AUTO=validate
HANDWRITE_FLYWAY_ENABLED=true

# ---- Redis ----
HANDWRITE_REDIS_HOST=127.0.0.1
HANDWRITE_REDIS_PORT=6379
HANDWRITE_REDIS_PASSWORD=
HANDWRITE_REDIS_DATABASE=0
HANDWRITE_REDIS_POOL_MAX_ACTIVE=16

# ---- Mail (SMTP) ----
HANDWRITE_MAIL_HOST=smtp.example.com
HANDWRITE_MAIL_PORT=465
HANDWRITE_MAIL_USERNAME=
HANDWRITE_MAIL_PASSWORD=
HANDWRITE_MAIL_SSL_TRUST=smtp.example.com

# ---- Upload ----
HANDWRITE_UPLOAD_MAX_FILE_SIZE=10MB
HANDWRITE_UPLOAD_MAX_REQUEST_SIZE=20MB

# ---- Logging ----
HANDWRITE_LOG_LEVEL_APP=DEBUG
HANDWRITE_LOG_FILE_PATH=logs/handwriting-client.log

# ---- JWT (⚠️ 生产环境必须修改 JWT_SECRET!) ----
# 重新生成：openssl rand -base64 32
HANDWRITE_JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZWZhdWx0LWp3dC1zZWNyZXQ=
HANDWRITE_JWT_ISSUER=handwriting-client
HANDWRITE_JWT_ACCESS_TTL=900
HANDWRITE_JWT_REFRESH_TTL=604800
HANDWRITE_JWT_HEADER=Authorization
HANDWRITE_JWT_PREFIX=Bearer

# ---- CORS ----
HANDWRITE_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Object Storage (MinIO / S3 / Azure Blob) ----
# 通用
HANDWRITE_STORAGE_PROVIDER=minio
HANDWRITE_STORAGE_BUCKET_COLLECT=handwriting-collect
HANDWRITE_STORAGE_BUCKET_AUDIT=handwriting-audit
HANDWRITE_STORAGE_BUCKET_BACKUP=handwriting-backup
HANDWRITE_STORAGE_PRESIGN_EXPIRE=600
HANDWRITE_STORAGE_PUBLIC_BASE_URL=
# MinIO / S3（HANDWRITE_STORAGE_PROVIDER=minio 或 s3 时使用）
HANDWRITE_STORAGE_ENDPOINT=http://127.0.0.1:9000
HANDWRITE_STORAGE_ACCESS_KEY=minio
HANDWRITE_STORAGE_SECRET_KEY=minio123
HANDWRITE_STORAGE_REGION=us-east-1
# Azure Blob Storage（HANDWRITE_STORAGE_PROVIDER=azure 时使用）
#   鉴权优先级：HANDWRITE_AZURE_CONNECTION_STRING > HANDWRITE_AZURE_SAS_TOKEN > (HANDWRITE_AZURE_STORAGE_ACCOUNT + HANDWRITE_AZURE_STORAGE_KEY)
HANDWRITE_AZURE_STORAGE_ACCOUNT=
HANDWRITE_AZURE_STORAGE_KEY=
HANDWRITE_AZURE_SAS_TOKEN=
HANDWRITE_AZURE_CONNECTION_STRING=
HANDWRITE_AZURE_CLOUD=china          # china | global | usgov

# ---- Rate Limit ----
HANDWRITE_RATELIMIT_AUTH_PER_MIN=20
HANDWRITE_RATELIMIT_UPLOAD_PER_MIN=60
