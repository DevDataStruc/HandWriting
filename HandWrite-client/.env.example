# ============================================================================
# HandWrite-client 环境变量样例
# 复制为 .env 后填入实际值： cp .env.example .env
# 在 IDE / CI / Docker 中以环境变量方式注入亦可
# ============================================================================

# ----- 服务自身 -----
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/
SERVER_TOMCAT_MAX_THREADS=200
SPRING_PROFILES_ACTIVE=dev
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL_APP=INFO
LOG_FILE_PATH=logs/handwriting-client.log

# ----- MySQL -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=handwriting
DB_USERNAME=handwriting
DB_PASSWORD=change-me-in-prod
DB_USE_SSL=false
DB_TIMEZONE=Asia/Shanghai
DB_POOL_MAX=20
DB_POOL_MIN=5

# ----- JPA / Flyway -----
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true

# ----- Redis -----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_POOL_MAX_ACTIVE=16

# ----- 邮件 (审核通知 / 找回密码) -----
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=change-me-in-prod
MAIL_SSL_TRUST=smtp.example.com

# ----- 文件上传上限 (备用) -----
UPLOAD_MAX_FILE_SIZE=10MB
UPLOAD_MAX_REQUEST_SIZE=20MB

# ----- JWT -----
# 推荐使用： openssl rand -base64 32
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZWZhdWx0LWp3dC1zZWNyZXQ=
JWT_ISSUER=handwriting-client
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_HEADER=Authorization
JWT_PREFIX="Bearer "

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ----- 对象存储 (MinIO / S3) -----
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=change-me-in-prod
STORAGE_REGION=us-east-1
STORAGE_BUCKET_COLLECT=handwriting-collect
STORAGE_BUCKET_AUDIT=handwriting-audit
STORAGE_BUCKET_BACKUP=handwriting-backup
STORAGE_PRESIGN_EXPIRE=600
STORAGE_PUBLIC_BASE_URL=

# ----- 限流 -----
RATELIMIT_AUTH_PER_MIN=20
RATELIMIT_UPLOAD_PER_MIN=60
